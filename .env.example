ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

KAVENEGAR_API_KEY=your_kavenegar_api_key

ZARINPAL_MERCHANT_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX
CALLBACK_URL=http://localhost:3000/payment/verify

NODE_ENV=development

# Site identity — set per deployment
# SITE_NAME: display name shown in navbar/footer/title
# SITE_DOMAIN: used for canonical links
# SHOW_ENAMAD: set to "true" only on the Iranian server (ramayt.ir)
SITE_NAME=رمیت
SITE_DOMAIN=ramayt.ir
SHOW_ENAMAD=true

# For the international server (sejil.org):
# SITE_NAME=Sejil
# SITE_DOMAIN=sejil.org
# SHOW_ENAMAD=false
